{
  "expo": {
    "name": "SleepFlow - White Noise",
    "slug": "sleepflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sleepflow.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      },
      "package": "com.sleepflow.app",
      "permissions": [
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5933378571335845~7971517649"
        }
      ],
      "react-native-iap",
      "expo-notifications"
    ],
    "scheme": "sleepflow",
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "0da1b0d8-f5b7-4ff1-bc09-8fe69a9fa3c1"
      },
      "router": {}
    },
    "owner": "kralkan"
  }
}
